{
  "name": "Dashboard Header",
  "renderType": "single",
  "componentProperties": {
    "title": { "type": "TEXT", "defaultValue": "Dashboard Title · 2025" }
  },
  "base": {
    "layoutMode": "HORIZONTAL",
    "primaryAxisAlignItems": "SPACE_BETWEEN",
    "counterAxisAlignItems": "CENTER",
    "primaryAxisSizingMode": "AUTO",
    "counterAxisSizingMode": "FIXED",
    "height": 44,
    "itemSpacing": { "var": "spacing/base", "fallback": 16 },
    "paddingTop": 0,
    "paddingBottom": 0,
    "paddingLeft": { "var": "spacing/xl", "fallback": 24 },
    "paddingRight": { "var": "spacing/xl", "fallback": 24 },
    "fillColor": { "var": "surface/header", "fallback": "#1a1917" },
    "fontFamily": "IBM Plex Sans"
  },
  "children": [
    {
      "name": "title",
      "type": "TEXT",
      "fontFamily": "IBM Plex Sans",
      "fontStyle": "SemiBold",
      "fontSize": { "var": "fontSize/heading-panel", "fallback": 13 },
      "lineHeight": 18.2,
      "letterSpacing": 0.39,
      "characters": "Dashboard Title · 2025",
      "textColor": { "var": "text/on-dark", "fallback": "#ffffff" },
      "propertyRef": { "characters": "title" }
    },
    {
      "name": "kpis",
      "type": "FRAME",
      "layoutMode": "HORIZONTAL",
      "primaryAxisAlignItems": "CENTER",
      "counterAxisAlignItems": "CENTER",
      "primaryAxisSizingMode": "AUTO",
      "counterAxisSizingMode": "AUTO",
      "itemSpacing": { "var": "spacing/sm", "fallback": 8 },
      "fills": [],
      "children": [
        {
          "name": "chip-1",
          "type": "COMPONENT_INSTANCE",
          "componentName": "KPI Chip",
          "overrides": {
            "value": "10 Tools",
            "label": "TRACKED"
          }
        },
        {
          "name": "chip-2",
          "type": "COMPONENT_INSTANCE",
          "componentName": "KPI Chip",
          "overrides": {
            "value": "7.5B",
            "label": "MONTHLY VISITS"
          }
        },
        {
          "name": "chip-3",
          "type": "COMPONENT_INSTANCE",
          "componentName": "KPI Chip",
          "overrides": {
            "value": "$4.9B",
            "label": "EST. REVENUE"
          }
        }
      ]
    }
  ]
}
